<UserControl x:Class="AlphaXSpreadSamplesExplorer.SamplesSideBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="280">
    <Border Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search Bar Header -->
            <Border Grid.Row="0" Padding="12,12,12,8">
                <Grid>
                    <TextBox x:Name="_txtSearch" Style="{StaticResource ModernTextBox}"
                             Padding="28,7,10,7" 
                             TextChanged="OnSearchTextChanged"/>
                    <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                          Fill="#A1A1AA" Width="13" Height="13" Stretch="Uniform"
                          HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Grouped Samples ListBox -->
            <ListBox x:Name="_lbSamples" Grid.Row="1" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single" Margin="4,0"
                     SelectionChanged="OnSampleSelectionChanged">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="#71717A" FontSize="10" FontWeight="Bold" 
                                           Margin="10,14,10,4"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Margin" Value="2,2,2,2"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Name="_Border" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="8" Padding="8,7,8,7" SnapsToDevicePixels="true">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Active Indicator Pill -->
                                            <Rectangle x:Name="_Indicator" Width="3" Height="16" RadiusX="1.5" RadiusY="1.5"
                                                       Fill="#18181B" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       Margin="-8,0,6,0" Visibility="Collapsed"/>

                                            <!-- Vector Icon -->
                                            <Path x:Name="_IconPath" Grid.Column="0" Data="{Binding IconData}"
                                                  Fill="#71717A" Width="15" Height="15" Stretch="Uniform"
                                                  VerticalAlignment="Center" Margin="2,0,10,0"/>

                                            <!-- Text Information -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="_TxtTitle" Text="{Binding Title}" FontSize="12.5" FontWeight="Medium" Foreground="#27272A"/>
                                                <TextBlock x:Name="_TxtDesc" Text="{Binding Description}" FontSize="11" Foreground="#71717A"
                                                           TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="true">
                                            <Setter TargetName="_Border" Property="Background" Value="#F4F4F5"/>
                                            <Setter TargetName="_TxtTitle" Property="Foreground" Value="#18181B"/>
                                            <Setter TargetName="_IconPath" Property="Fill" Value="#3F3F46"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="true">
                                            <Setter TargetName="_Border" Property="Background" Value="#FFFFFF"/>
                                            <Setter TargetName="_Border" Property="BorderBrush" Value="#E4E4E7"/>
                                            <Setter TargetName="_TxtTitle" Property="Foreground" Value="#18181B"/>
                                            <Setter TargetName="_TxtTitle" Property="FontWeight" Value="SemiBold"/>
                                            <Setter TargetName="_TxtDesc" Property="Foreground" Value="#52525B"/>
                                            <Setter TargetName="_IconPath" Property="Fill" Value="#18181B"/>
                                            <Setter TargetName="_Indicator" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Footer info -->
            <Border Grid.Row="2" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="#E4E4E7">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="AlphaX Sheets Showcase" Foreground="#A1A1AA" FontSize="11" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
