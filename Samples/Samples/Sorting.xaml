<UserControl x:Class="AlphaXSpreadSamplesExplorer.Samples.Sorting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer.Samples" 
             xmlns:sheets="http://schemas.gcspreadsheet.com/2022/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Range Sorting:" VerticalAlignment="Center" FontWeight="Medium" Foreground="#3F3F46" Margin="0,0,12,0"/>
                <Button Content="Sort Ascending ▲" Style="{StaticResource ModernButton}" Click="OnSortAscending" Margin="0,0,8,0"/>
                <Button Content="Sort Descending ▼" Style="{StaticResource ModernOutlineButton}" Click="OnSortDescending" Margin="0,0,16,0"/>
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="8,4">
                    <TextBlock Text="Select any column range to trigger automated multi-row sorting." 
                               Foreground="#52525B" FontSize="11" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Spreadsheet View -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E4E4E7" CornerRadius="6">
            <sheets:AlphaXSpread x:Name="spread"/>
        </Border>
    </Grid>
</UserControl>
