<UserControl x:Class="AlphaXSpreadSamplesExplorer.Samples.ScrollModes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer.Samples"
             xmlns:sheets="http://schemas.gcspreadsheet.com/2022/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Scroll Mode Option:" VerticalAlignment="Center" FontWeight="Medium" Foreground="#3F3F46" Margin="0,0,10,0"/>
                <ComboBox x:Name="_cmbScrollMode" Style="{StaticResource ModernComboBox}"
                          Width="160" SelectedIndex="0" VerticalAlignment="Center">
                    <ComboBoxItem Tag="Item">Item Scrolling</ComboBoxItem>
                    <ComboBoxItem Tag="Pixel">Pixel Scrolling</ComboBoxItem>
                    <ComboBoxItem Tag="Deferred">Deferred Scrolling</ComboBoxItem>
                </ComboBox>
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="16,0,0,0">
                    <TextBlock Text="Item mode scrolls row-by-row; Pixel mode provides smooth continuous scrolling." 
                               Foreground="#52525B" FontSize="11" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Spreadsheet View -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E4E4E7" CornerRadius="6">
            <sheets:AlphaXSpread x:Name="spread" ScrollMode="{Binding ElementName=_cmbScrollMode, Path=SelectedItem.Tag, Mode=TwoWay}"/>
        </Border>
    </Grid>
</UserControl>
