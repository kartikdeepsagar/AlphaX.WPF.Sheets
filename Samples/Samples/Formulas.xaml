<UserControl x:Class="AlphaXSpreadSamplesExplorer.Samples.Formulas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer.Samples"
             xmlns:sheets="http://schemas.gcspreadsheet.com/2022/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Background="#107C41" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Multi-Sheet Formulas &amp; Dependent Calculation Engine" 
                           Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBlock Text="Demonstrating basic, advanced, dependent, and cross-sheet interlinked formulas across multiple worksheets." 
                           Foreground="#E0F2E9" FontSize="12" Margin="0,4,0,0" FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Feature Badges & Info Bar -->
        <Border Grid.Row="1" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
            <WrapPanel VerticalAlignment="Center">
                <Border Background="#E0F2FE" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="🔗 Interlinked Sheets" Foreground="#0369A1" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FEE2E2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="⚡ Dependent Formulas" Foreground="#B91C1C" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="📊 SUM, AVG, MIN, MAX, COUNT" Foreground="#B45309" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#DCFCE7" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="🔄 Real-Time Recalculation" Foreground="#15803D" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Try editing any value in 'Regional Sales' to see 'Summary Dashboard' update!" 
                           Foreground="#4B5563" FontSize="11" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- Main Spread Control -->
        <sheets:AlphaXSpread x:Name="spread" Grid.Row="2"/>
    </Grid>
</UserControl>
