<UserControl x:Class="AlphaXSpreadSamplesExplorer.Samples.CellTypes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer.Samples"
             xmlns:sheets="http://schemas.gcspreadsheet.com/2022/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Feature Info -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
            <WrapPanel VerticalAlignment="Center">
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="☑ Checkbox Cell" Foreground="#3F3F46" FontSize="11" FontWeight="Medium"/>
                </Border>
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="🔘 Button Cell" Foreground="#3F3F46" FontSize="11" FontWeight="Medium"/>
                </Border>
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="▼ ComboBox Cell" Foreground="#3F3F46" FontSize="11" FontWeight="Medium"/>
                </Border>
                <Border Background="#F4F4F5" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="✏ Text Cell" Foreground="#3F3F46" FontSize="11" FontWeight="Medium"/>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Spreadsheet Container -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E4E4E7" CornerRadius="6">
            <sheets:AlphaXSpread x:Name="spread"/>
        </Border>
    </Grid>
</UserControl>
