<UserControl x:Class="AlphaXSpreadSamplesExplorer.Testing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer" 
             xmlns:sheets="http://schemas.gcspreadsheet.com/2022/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Formula Bar Header Container -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#18181B" CornerRadius="4" Padding="7,3" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="fx" Foreground="White" FontWeight="Bold" FontSize="12" FontFamily="Consolas, Segoe UI"/>
                </Border>

                <sheets:AlphaXFormulaTextBox Grid.Column="1" Spread="{Binding ElementName=spread}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Spreadsheet View -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E4E4E7" CornerRadius="6">
            <sheets:AlphaXSpread x:Name="spread"/>
        </Border>
    </Grid>
</UserControl>
