<Window x:Class="AlphaXSpreadSamplesExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlphaXSpreadSamplesExplorer"
        mc:Ignorable="d" WindowState="Maximized"
        Title="AlphaX Spread Samples Explorer" Height="650" Width="1000">
    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="AlphaX Spread" FontSize="18" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                <TextBlock Text=" | Feature Showcase &amp; Samples Explorer" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content Split View -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:SamplesSideBar x:Name="_samplesSideBar" Margin="8,8,4,8"
                                  Grid.Column="0"
                                  SampleSelected="OnSampleSelected"/>

            <GridSplitter Grid.Column="0" Width="4"
                          Margin="0,8,0,8"
                          Background="#CBD5E1"
                          HorizontalAlignment="Right"
                          ShowsPreview="True" 
                          ResizeDirection="Columns"/>
            
            <Border x:Name="_samplesViewerBdr" Grid.Column="1" BorderThickness="1" 
                    BorderBrush="#E2E8F0" Background="White" Margin="4,8,8,8" Padding="5" CornerRadius="4">
            </Border>
        </Grid>
    </Grid>
</Window>
