<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:components="clr-namespace:AlphaX.WPF.Sheets.Components"
                    xmlns:gc="http://schemas.gcspreadsheet.com/2022/wpf"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style x:Key="ToolBarButtonStyle" TargetType="ButtonBase">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#5F6368" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="2,3" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ButtonBase">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="6,4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E2E4E7" />
                            <Setter Property="Foreground" Value="#1F2937" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#D0D4DC" />
                            <Setter Property="Foreground" Value="#111827" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#C0C4CC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SheetTabItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1,0,1,0" />
        <Setter Property="Margin" Value="2,-1,2,0" />
        <Setter Property="Padding" Value="14,6,14,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="mainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4,4,0,0">
                        <Grid>
                            <ContentPresenter x:Name="contentPresenter"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />

                            <Rectangle x:Name="activeAccentBar"
                                       Height="3"
                                       VerticalAlignment="Bottom"
                                       Fill="#107C41"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="mainBorder" Property="Background" Value="#E5E7EB" />
                            <Setter Property="Foreground" Value="#111827" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="mainBorder" Property="Background" Value="#FFFFFF" />
                            <Setter TargetName="mainBorder" Property="BorderBrush" Value="#D1D5DB" />
                            <Setter TargetName="activeAccentBar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="#1F2937" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type components:AlphaXSheetTabControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type components:AlphaXSheetTabControl}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid x:Name="_root">
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="_sheetViewPaneBorder"></Border>

                            <Border x:Name="vScrollBarBorder"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Background="#F3F4F6">
                                <ScrollBar x:Name="_vScrollBar"
                                           Margin="6,6,6,6"
                                           Style="{Binding Path=ScrollBarStyle, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=gc:AlphaXSpread}}"/>
                            </Border>

                            <Border x:Name="toolBarBorder"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Background="#F3F4F6"
                                    Padding="0"
                                    BorderThickness="0">
                                <Grid x:Name="toolBarGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                        <ColumnDefinition Width="auto" MaxWidth="500"></ColumnDefinition>
                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                        <ColumnDefinition Width="*" ></ColumnDefinition>
                                    </Grid.ColumnDefinitions>

                                     <StackPanel Grid.Column="0" 
                                                Visibility="{Binding Path=SheetTabsVisibility, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=gc:AlphaXSpread}}"
                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="4,-2,4,2">
                                        <RepeatButton x:Name="_btnPrevious"
                                                      Width="26"
                                                      Height="26"
                                                      VerticalAlignment="Center"
                                                      ToolTip="Select previous sheet"
                                                      Style="{StaticResource ToolBarButtonStyle}" 
                                                      Content="‹"
                                                      FontSize="15"
                                                      FontWeight="Bold">
                                        </RepeatButton>

                                        <RepeatButton x:Name="_btnNext" 
                                                      Style="{StaticResource ToolBarButtonStyle}"
                                                      VerticalAlignment="Center"
                                                      Width="26"
                                                      Height="26"
                                                      ToolTip="Select next sheet"
                                                      Content="›"
                                                      FontSize="15"
                                                      FontWeight="Bold">
                                        </RepeatButton>
                                    </StackPanel>

                                    <ListBox x:Name="_sheetsListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Visibility="{Binding Path=SheetTabsVisibility, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=gc:AlphaXSpread}}"
                                             MaxWidth="400"
                                             VerticalAlignment="Top"
                                             Margin="0,-1,0,0"
                                             ItemContainerStyle="{StaticResource SheetTabItemStyle}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.CanContentScroll="False"
                                             Grid.Column="1">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding WorkSheet.Name}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>

                                    <Button x:Name="_btnAddSheet" 
                                            Visibility="{Binding Path=SheetTabsVisibility, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=gc:AlphaXSpread}}"
                                            Grid.Column="2"
                                            Margin="4,-2,4,2"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource ToolBarButtonStyle}"
                                            ToolTip="Add new sheet"
                                            Width="26"
                                            Height="26"
                                            Content="+"
                                            FontSize="15"
                                            FontWeight="Normal"></Button>

                                    <ScrollBar x:Name="_hScrollBar" 
                                               Style="{Binding Path=ScrollBarStyle, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=gc:AlphaXSpread}}"
                                               Grid.Column="3" 
                                               Margin="6,6,6,6"
                                               Orientation="Horizontal"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>